# ── GitHub (required for pushing configs) ──────────────────────────
# Personal Access Token with repo scope
# Create at: https://github.com/settings/tokens
# Falls back to MY_TOKEN env var for backward compat
GITHUB_TOKEN=

# Target repository in owner/repo format
REPO_NAME=whoahaow/rjsxrd


# ── Telegram notifications (optional) ─────────────────────────────
# Bot token from @BotFather and your chat/user ID
# If not set, notifications are silently skipped
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ── Performance tuning (optional, defaults shown) ─────────────────
# Max concurrent xray processes on Linux/WSL
# Each process ~50MB RAM peak. 300 = ~15GB peak.
# Lower if you see OOM kills: ASYNC_CONCURRENCY_LINUX=50
# ASYNC_CONCURRENCY_LINUX=300

# Download concurrency (threads for fetching URLs)
# MAX_WORKERS=50

# HTTP request timeout in seconds
# FETCH_TIMEOUT=5
# VALIDATION_HTTP_TIMEOUT=5

# ── Xray config generation (optional, defaults shown) ─────────────
# Test URL(s) for ping verification. Comma-separated list.
# Default: https://www.gstatic.com/generate_204
# TEST_PING_URLS=https://www.gstatic.com/generate_204

# TLS fingerprint for Xray outbound connections
# Options: chrome, firefox, safari, edge, randomized
# TLS_FINGERPRINT=chrome

# TLS fragment (stealth) — splits Client Hello to evade DPI
# ENABLE_FRAGMENT=true
# FRAGMENT_PACKETS=tlshello
# FRAGMENT_LENGTH=100-200
# FRAGMENT_INTERVAL=10-20
